# Adzuna API credentials — register free at https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# RapidAPI key for JSearch (LinkedIn jobs) — subscribe free at rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key

# Your contact details — copied to clipboard when you click Apply
APPLY_NAME=Your Full Name
APPLY_EMAIL=your@email.com
APPLY_PHONE=+972xxxxxxxxx
APPLY_LINKEDIN=https://www.linkedin.com/in/your-profile/

# Email address to receive daily job digest notifications
NOTIFY_EMAIL=your@email.com

# SMTP settings for sending email notifications
# For Gmail: host=smtp.gmail.com, port=587
# Use an App Password (not your main password): https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password

# Port for the backend API server (default: 3001)
PORT=3001
